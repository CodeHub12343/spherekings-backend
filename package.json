{
  "name": "spherekings-marketplace-and-afiliates",
  "version": "1.0.0",
  "description": "E-commerce marketplace with integrated affiliate marketing system for Sphere of Kings board game",
  "main": "src/server.js",
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
